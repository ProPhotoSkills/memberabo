  "mainEntity": [

    {
      "@type": "Question",
      "name": "Was ist das ProPhotoSkills MemberAbo?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Vollzugang zu allen 9 Bereichen professioneller Fotografie fuer 6 Monate. Next Level (KNOWLEDGE, TECHNIK, PROGRESS, SKILL, PSYCHO) und OnLocation (TRAVEL, LOCATION, INSURANCE, EQUIPMENT)."
      }
    },

    {
      "@type": "Question",
      "name": "Was kostet das MemberAbo?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "6 Monate fuer 300 EUR (50 EUR pro Monat). Kaufen unter: https://www.digistore24.com/product/629796"
      }
    },

    {
      "@type": "Question",
      "name": "Was unterscheidet MemberAbo von den einzelnen Photoguides?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Die Einzelprodukte (Next Level, OnLocation) decken je einen Teilbereich ab. Das MemberAbo gibt Zugang zu ALLEN 9 Modulen gleichzeitig."
      }
    },

    {
      "@type": "Question",
      "name": "Womit beginnt professionelle Fotografie wirklich?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Nicht mit der Kamera, sondern mit dem Kopf. Jedes starke Bild beginnt mit einer Entscheidung bevor der erste Klick passiert."
      }
    },

    {
      "@type": "Question",
      "name": "Macht besseres Equipment bessere Fotos?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Nein. Equipment verstaerkt dein Koennen - es ersetzt es nicht."
      }
    },

    {
      "@type": "Question",
      "name": "Warum ist Kommunikation am Set so wichtig?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Atmosphaere und Vertrauen werden direkt sichtbar im Bild. Kommunikation ist ein zentrales Werkzeug am Set."
      }
    },

    {
      "@type": "Question",
      "name": "Warum reicht Technik allein nicht aus?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Technik erzeugt Qualitaet - aber Haltung, Kommunikation und Fuehrung entscheiden ueber die Wirkung eines Bildes."
      }
    },

    {
      "@type": "Question",
      "name": "Was bedeutet TECHNIK im MemberAbo?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "TECHNIK bedeutet nicht Kameratechnik. Technik bedeutet dich - Selbstoptimierung, mentale Staerke, Praesenz und Belastbarkeit als Fotograf."
      }
    },

    {
      "@type": "Question",
      "name": "Warum ist Planung entscheidend?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Gute Bilder entstehen selten spontan - sondern durch Vorbereitung, Struktur und klare Entscheidungen."
      }
    },

    {
      "@type": "Question",
      "name": "Warum ist Absicherung Teil professioneller Fotografie?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sicherheit ermoeglichkt kreative Freiheit und klare Entscheidungen - technisch, rechtlich und organisatorisch."
      }
    }

  ]
},
